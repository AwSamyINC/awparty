# Нормализуем переводы строк: в репозитории — LF, в рабочей копии — как в ОС.
* text=auto
*.js   text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md   text eol=lf

# Git-хуки и .sh — строго LF и в рабочей копии (иначе sh: #!/bin/sh\r → bad interpreter).
scripts/hooks/* text eol=lf
*.sh   text eol=lf

# Бинарные ассеты не трогаем.
*.png  binary
*.jpg  binary
*.wav  binary
*.mp3  binary
*.ttf  binary
*.ico  binary
